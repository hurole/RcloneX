{
  "name": "RcloneX",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "check": "tsc",
    "dev": "rsbuild dev --open",
    "fmt": "oxfmt .",
    "lint": "oxlint",
    "preview": "rsbuild preview",
    "start:rclone": "rclone rcd --rc-addr :5572 --rc-user dev --rc-pass 1234 --rc-allow-origin http://localhost:3000",
    "test": "vitest run",
    "sentry": "sentry-cli sourcemaps upload ./dist --release $(node -p \"require('./package.json').version\") --url-prefix ~/"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@sentry/react": "^10.65.0",
    "axios": "^1.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^24.2.2",
    "i18next-browser-languagedetector": "^8.0.4",
    "lucide-react": "^0.485.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "react-i18next": "^15.4.1",
    "react-router": "^7.3.0",
    "sonner": "^2.0.2",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.2.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@fka/oxfmt-config": "^0.1.1",
    "@rsbuild/core": "^2.1.5",
    "@rsbuild/plugin-react": "^2.1.0",
    "@sentry/cli": "^3.5.0",
    "@tailwindcss/postcss": "^4.0.12",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.12",
    "typescript": "^7.0.2",
    "vitest": "^4.1.8"
  },
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.4.8",
      "onFail": "warn"
    }
  },
  "allowBuilds": {
    "@sentry/cli": true
  }
}
